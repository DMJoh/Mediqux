{
  "name": "mediqux-backend",
  "version": "1.0.0",
  "description": "Mediqux Backend",
  "main": "server.js",
  "scripts": {
    "dev": "npx nodemon server.js",
    "start": "node server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:create": "npx sequelize-cli db:create",
    "db:drop": "npx sequelize-cli db:drop"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.18.0",
    "cors": "^2.8.6",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "dotenv": "^17.2.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.5",
    "pg-hstore": "^2.3.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}